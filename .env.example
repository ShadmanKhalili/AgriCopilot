# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# OPENWEATHER_API_KEY: Required for weather data.
# Get one at https://openweathermap.org/api
VITE_OPENWEATHER_API_KEY=

# Copernicus Data Space Ecosystem Credentials (Free Sentinel-2 Data)
# Get them at https://dataspace.copernicus.eu/ (Dashboard -> User Settings -> OAuth Clients)
SENTINEL_HUB_CLIENT_ID=
SENTINEL_HUB_CLIENT_SECRET=

# Agromonitoring API Key (Satellite Imagery)
# Get one at https://agromonitoring.com/
AGROMONITORING_API_KEY=

# Google AdSense
# VITE_ENABLE_ADS=false to disable ads globally
VITE_ENABLE_ADS=true
VITE_ADSENSE_CLIENT_ID=ca-pub-8294149074042302
VITE_ADSENSE_SLOT_ID=
