rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Shared Primitives
    // ===============================================================
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isSignedIn() && 
        (request.auth.token.email == "sadmankhalili@gmail.com" && request.auth.token.email_verified == true);
    }

    function isDatabaseAdmin() {
      // Identity isolation: We don't want users to spoof admin role in their profile
      // so we use a hardcoded email for the bootstrapper admin
      return isAdmin();
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Pillars: Standard type checks with size bounds
    function isStr(val, min, max) {
      return val is string && val.size() >= min && val.size() <= max;
    }

    function isTimestamp(val) {
      // Perceived as ISO string by the app
      return val is string && val.size() >= 19;
    }

    // ===============================================================
    // Entity Validators (Pillar 2)
    // ===============================================================

    function isValidUser(data) {
      // uid, email, name, role, tier, usageCount, lastUsedDate, createdAt
      return data.keys().hasAll(['uid', 'email', 'role', 'tier', 'usageCount', 'createdAt']) &&
             isStr(data.uid, 1, 128) &&
             isStr(data.email, 3, 128) &&
             data.usageCount is number &&
             isTimestamp(data.createdAt);
    }

    function isValidDiagnosis(data) {
      // userId, crop, cropStage, analysisType, diagnosisText, qualitativeSeverity, symptomsBreakdown, verificationAdvice, createdAt
      return data.keys().hasAll(['userId', 'crop', 'cropStage', 'analysisType', 'diagnosisText', 'qualitativeSeverity', 'symptomsBreakdown', 'verificationAdvice', 'createdAt']) &&
             isStr(data.userId, 1, 128) &&
             isStr(data.diagnosisText, 1, 30000) &&
             isTimestamp(data.createdAt);
    }

    function isValidCertificate(data) {
      let requiredFields = ['userId', 'produce', 'grade', 'justification', 'estimatedPriceBdt', 'createdAt'];
      return data.keys().hasAll(requiredFields) &&
             isStr(data.userId, 1, 128) &&
             isStr(data.produce, 1, 128) &&
             isStr(data.grade, 1, 64) &&
             isStr(data.justification, 1, 5000) &&
             data.estimatedPriceBdt is number &&
             isTimestamp(data.createdAt);
    }

    function isValidAlert(data) {
      let requiredFields = ['userId', 'scenario', 'message', 'createdAt'];
      return data.keys().hasAll(requiredFields) &&
             isStr(data.userId, 1, 128) &&
             isStr(data.scenario, 1, 256) &&
             isStr(data.message, 1, 5000) &&
             isTimestamp(data.createdAt);
    }

    function isValidMarketQuery(data) {
      let requiredFields = ['userId', 'produce', 'insights', 'isAdvanced', 'createdAt'];
      return data.keys().hasAll(requiredFields) &&
             isStr(data.userId, 1, 128) &&
             isStr(data.produce, 1, 128) &&
             isStr(data.insights, 1, 10000) &&
             data.isAdvanced is bool &&
             isTimestamp(data.createdAt);
    }

    function isValidPlantingIntent(data) {
      let requiredFields = ['userId', 'latitude', 'longitude', 'landType', 'landSize', 'irrigation', 'previousCrop', 'budget', 'targetTime', 'recommendedCrop', 'createdAt'];
      return data.keys().hasAll(requiredFields) &&
             isStr(data.userId, 1, 128) &&
             data.latitude is number &&
             data.longitude is number &&
             isStr(data.landType, 1, 128) &&
             isStr(data.landSize, 1, 128) &&
             isStr(data.irrigation, 1, 128) &&
             isStr(data.previousCrop, 1, 128) &&
             isStr(data.budget, 1, 128) &&
             isStr(data.targetTime, 1, 128) &&
             isStr(data.recommendedCrop, 1, 128) &&
             isTimestamp(data.createdAt);
    }

    // ===============================================================
    // Rules Enforcement
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isSignedIn() && isValidUser(incoming()) && 
                    incoming().uid == request.auth.uid &&
                    userId == request.auth.uid;
      allow update: if isSignedIn() && isValidUser(incoming()) &&
                    isOwner(userId) &&
                    incoming().uid == existing().uid &&
                    incoming().email == existing().email &&
                    incoming().createdAt == existing().createdAt &&
                    (
                      isAdmin() || 
                      (
                        // Tier upgrade or Usage Count sync
                        incoming().diff(existing()).affectedKeys().hasAny(['tier', 'usageCount', 'lastUsedDate', 'name']) &&
                        incoming().diff(existing()).affectedKeys().hasOnly(['tier', 'usageCount', 'lastUsedDate', 'name'])
                      )
                    );
      allow delete: if isAdmin();
    }

    match /diagnoses/{diagnosisId} {
      // Secure List Query (Pillar 8)
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      
      allow create: if isSignedIn() && isValidDiagnosis(incoming()) &&
                    incoming().userId == request.auth.uid;
      
      allow update: if isSignedIn() && isValidDiagnosis(incoming()) &&
                    existing().userId == request.auth.uid &&
                    incoming().userId == existing().userId &&
                    incoming().createdAt == existing().createdAt &&
                    (
                      isAdmin() ||
                      (
                        // Action based update
                        incoming().diff(existing()).affectedKeys().hasAny(['deepDiagnosis', 'deepDiagnosedAt', 'helpful', 'chatSummary']) &&
                        incoming().diff(existing()).affectedKeys().hasOnly(['deepDiagnosis', 'deepDiagnosedAt', 'helpful', 'chatSummary', 'updatedAt'])
                      )
                    );
      allow delete: if isAdmin();
    }

    match /certificates/{certificateId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidCertificate(incoming()) &&
                    incoming().userId == request.auth.uid &&
                    isValidId(certificateId);
      allow delete: if isAdmin();
    }

    match /alerts/{alertId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidAlert(incoming()) &&
                    incoming().userId == request.auth.uid &&
                    isValidId(alertId);
      allow delete: if isAdmin();
    }

    match /market_queries/{queryId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidMarketQuery(incoming()) &&
                    incoming().userId == request.auth.uid &&
                    isValidId(queryId);
      allow delete: if isAdmin();
    }

    match /planting_intents/{intentId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidPlantingIntent(incoming()) &&
                    incoming().userId == request.auth.uid &&
                    isValidId(intentId);
      allow delete: if isAdmin();
    }
    
    match /gov_schemes/{schemeId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
