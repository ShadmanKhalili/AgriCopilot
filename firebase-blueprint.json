{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile for Agri-Preneurs and Hub Managers",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["agri-preneur", "hub-manager", "admin"] },
        "tier": { "type": "string", "enum": ["free", "premium"] },
        "usageCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "tier", "usageCount", "createdAt"]
    },
    "Diagnosis": {
      "title": "Diagnosis",
      "description": "Record of a crop disease diagnosis",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "ID of the Agri-Preneur" },
        "crop": { "type": "string" },
        "cropStage": { "type": "string" },
        "analysisType": { "type": "string" },
        "diagnosisText": { "type": "string" },
        "qualitativeSeverity": { "type": "string", "enum": ["Low", "Medium", "High"] },
        "symptomsBreakdown": { 
          "type": "array",
          "items": { "type": "string" }
        },
        "verificationAdvice": { "type": "string" },
        "chatSummary": { "type": "string", "description": "AI-generated summary of the follow-up consultation" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "crop", "cropStage", "analysisType", "diagnosisText", "qualitativeSeverity", "symptomsBreakdown", "verificationAdvice", "createdAt"]
    },
    "QualityCertificate": {
      "title": "QualityCertificate",
      "description": "Record of a quality grading certificate",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "ID of the Hub Manager" },
        "produce": { "type": "string" },
        "grade": { "type": "string" },
        "justification": { "type": "string" },
        "estimatedPriceBdt": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "produce", "grade", "justification", "estimatedPriceBdt", "createdAt"]
    },
    "WeatherAlert": {
      "title": "WeatherAlert",
      "description": "Record of a broadcasted weather alert",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "ID of the user who triggered it" },
        "scenario": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "scenario", "message", "createdAt"]
    },
    "MarketQuery": {
      "title": "MarketQuery",
      "description": "Record of a market insight query",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "ID of the user who queried" },
        "produce": { "type": "string" },
        "insights": { "type": "string" },
        "isAdvanced": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "produce", "insights", "isAdvanced", "createdAt"]
    },
    "PlantingIntent": {
      "title": "PlantingIntent",
      "description": "Record of a farmer's planting intent and recommendation",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "latitude": { "type": "number" },
        "longitude": { "type": "number" },
        "landType": { "type": "string" },
        "landSize": { "type": "string" },
        "irrigation": { "type": "string" },
        "previousCrop": { "type": "string" },
        "budget": { "type": "string" },
        "targetTime": { "type": "string" },
        "recommendedCrop": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "latitude", "longitude", "landType", "landSize", "irrigation", "previousCrop", "budget", "targetTime", "recommendedCrop", "createdAt"]
    },
    "GovScheme": {
      "title": "GovScheme",
      "description": "A curated government scheme or farmer benefit",
      "type": "object",
      "properties": {
        "title": {
          "type": "object",
          "properties": {
            "en": { "type": "string" },
            "bn": { "type": "string" }
          }
        },
        "description": {
          "type": "object",
          "properties": {
            "en": { "type": "string" },
            "bn": { "type": "string" }
          }
        },
        "provider": { "type": "string" },
        "status": { "type": "string" },
        "eligibility": {
          "type": "object",
          "properties": {
            "en": { "type": "string" },
            "bn": { "type": "string" }
          }
        },
        "howToApply": {
          "type": "object",
          "properties": {
            "en": { "type": "string" },
            "bn": { "type": "string" }
          }
        },
        "crops": {
          "type": "array",
          "items": { "type": "string" }
        },
        "districts": {
          "type": "array",
          "items": { "type": "string" }
        },
        "sourceLinks": {
          "type": "array",
          "items": { "type": "string" }
        },
        "lastUpdated": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "description", "eligibility", "howToApply", "crops", "districts", "lastUpdated"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "Stores user profiles"
    },
    "/diagnoses/{diagnosisId}": {
      "schema": { "$ref": "#/entities/Diagnosis" },
      "description": "Stores crop diagnoses"
    },
    "/certificates/{certificateId}": {
      "schema": { "$ref": "#/entities/QualityCertificate" },
      "description": "Stores quality certificates"
    },
    "/alerts/{alertId}": {
      "schema": { "$ref": "#/entities/WeatherAlert" },
      "description": "Stores weather alerts"
    },
    "/market_queries/{queryId}": {
      "schema": { "$ref": "#/entities/MarketQuery" },
      "description": "Stores market insight queries"
    },
    "/planting_intents/{intentId}": {
      "schema": { "$ref": "#/entities/PlantingIntent" },
      "description": "Stores farmer planting intents and recommendations"
    },
    "/gov_schemes/{schemeId}": {
      "schema": { "$ref": "#/entities/GovScheme" },
      "description": "Stores curated government schemes for farmers"
    }
  }
}
